# Copier ce fichier vers .env et remplir les valeurs réelles.
# Le fichier .env ne doit JAMAIS être versionné ni partagé.
# ⚠️ Ne mettez AUCUNE valeur réelle ici : ce fichier est un modèle destiné à être partagé.

# Base de données MySQL (LWS)
# Créer la base dans le Panel LWS (rubrique MySQL), puis reporter dans .env :
# utilisateur, mot de passe, hôte ("Ip serveur" affiché dans le panel) et nom de la base.
# NB : si le mot de passe contient @ ou :, les encoder (%40 pour @, %3A pour :).
DATABASE_URL="mysql://utilisateur:motdepasse@hote-lws:3306/nom_de_la_base"

# URL publique du site (utilisée pour le SEO : sitemap, canoniques, Open Graph)
NEXT_PUBLIC_SITE_URL="https://www.ceforbe.com"

# SMTP pour les notifications e-mail des formulaires.
# Avec une boîte e-mail LWS (recommandé) : SMTP_HOST = serveur sortant indiqué
# dans le Panel LWS (généralement mail.votre-domaine.tld), SMTP_PORT=465,
# SMTP_USER = l'adresse complète, SMTP_PASS = le mot de passe de la boîte.
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""

# Expéditeur et destinataire des notifications
# Doit être la même adresse que SMTP_USER (exigence des serveurs LWS)
MAIL_FROM="CeForBE <contact@ceforbe.com>"
MAIL_TO="contact@ceforbe.com"

# Jeton d'accès à l'export CSV des inscriptions/messages (/api/admin/export).
# Choisir une longue chaîne aléatoire (40+ caractères). Laisser vide = export désactivé.
ADMIN_EXPORT_TOKEN=""
