generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

model Inscription {
  id               Int      @id @default(autoincrement())
  nom              String
  prenom           String
  email            String
  telephone        String
  formation        String
  message          String?  @db.Text
  date_inscription DateTime @default(now())
  langue           String   @default("fr")
  
  @@map("inscriptions")
}

model Contact {
  id           Int      @id @default(autoincrement())
  nom          String
  email        String
  telephone    String?
  sujet        String
  message      String   @db.Text
  date_contact DateTime @default(now())
  
  @@map("contacts")
}
